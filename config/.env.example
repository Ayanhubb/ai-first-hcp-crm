# =============================================================================
# AI-First HCP CRM — Environment Template
# Copy to repo root as `.env` (never commit real secrets)
# =============================================================================

# --- App ---
ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://localhost

# --- PostgreSQL ---
POSTGRES_USER=hcp_crm
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=hcp_crm
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://hcp_crm:change_me_strong_password@db:5432/hcp_crm

# --- JWT Auth ---
JWT_SECRET=change_me_to_a_long_random_secret
JWT_ACCESS_TTL=1800
JWT_REFRESH_TTL=604800
JWT_ALGORITHM=HS256

# --- Groq / AI ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
AI_TIMEOUT_SECONDS=60
AI_HISTORY_LIMIT=10

# --- Rate limiting (illustrative) ---
RATE_LIMIT_LOGIN_PER_15MIN=10
RATE_LIMIT_AI_PER_HOUR=30
RATE_LIMIT_API_PER_HOUR=600

# --- Frontend (build-time; prefer Nginx same-origin proxy) ---
VITE_API_BASE_URL=/api/v1

# --- Backend ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
